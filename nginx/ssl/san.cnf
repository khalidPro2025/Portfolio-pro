[req]
default_bits = 2048
prompt = no
default_md = sha256
distinguished_name = dn
req_extensions = req_ext

[dn]
C = SN
ST = Dakar
L = Dakar
O = PortfolioSecurite
CN = securite

[req_ext]
subjectAltName = @alt_names

[alt_names]
DNS.1 = securite
DNS.2 = localhost
DNS.3 = *.securite
IP.1 = 127.0.0.1
IP.2 = 192.168.1.11
IP.3 = 172.17.0.1
